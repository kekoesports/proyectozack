# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/
.firecrawl/

# weave coordinator runtime state (sessions, plans, active execution)
.weave/

# playwright artifacts
/test-results
/playwright-report
/blob-report
/.playwright-mcp

# local dev-server logs
.dev-server.log
.dev-server.err.log

# Python scraper
scraper/__pycache__/
scraper/sources/__pycache__/
scraper/*.pyc

# ad-hoc visual testing screenshots (Playwright MCP)
visual-*.png
crm-*-smoke.png
screenshots/

# One-off QA capture scripts with hardcoded local paths
scripts/capture_*.mjs

# Local agent/IDE settings (never commit)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Local issue tracker / PRD scratch — ephemeral planning, decisions live in code + ADRs
.scratch/

# Skill audit logs — contain PII (creator bios, contacts, follower counts)
.claude/skills/socialpro-creator-targets/runs/*.md
!.claude/skills/socialpro-creator-targets/runs/.gitkeep
.env*.local

# Local video teaser scripts + generated clips/outputs (experimental, no van al repo)
scripts/video-teaser/
